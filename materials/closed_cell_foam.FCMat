; FreeCAD material card for closed-cell foam
; Used for collar padding, hip belt padding
; NOTE: For hyperfoam modeling in CalculiX, use manual .inp
;       with *HYPERFOAM, N=1

[General]
Name = closed_cell_foam
Description = Closed-cell foam (XPE/EVA) for collar and hip belt padding
Father = None

[Mechanical]
Density = 65 kg/m^3
YoungsModulus = 2.4 MPa
PoissonRatio = 0.0

[Thermal]
ThermalConductivity = 0.04 W/m/K
SpecificHeat = 2100 J/kg/K
